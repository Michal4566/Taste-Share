<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/recipe_card"
    style="@style/RoundedCardAppearance"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/primary">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/recipe_image"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:background="@drawable/default_recipe_image"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Recipe Information Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="8sp"
            app:layout_constraintStart_toEndOf="@id/recipe_image"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Recipe Title -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/recipe_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/accent"
                android:textStyle="bold"
                android:lines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"
                android:text="@string/recipe_name" />

            <!-- Recipe Details Row (Cuisine, Time, and Rating) -->
            <LinearLayout
                android:id="@+id/cuisine_and_time_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">

                <!-- Cuisine Type -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/recipe_cuisine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:text="@string/cuisine_filter"
                    android:layout_marginEnd="4dp" />

                <!-- Divider Dot -->
                <TextView
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/rounded_dot"
                    android:layout_marginEnd="4dp"
                    android:gravity="center" />

                <!-- Meal Type or Rating -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/additional_text_view"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:text="@string/meal_filter" />
            </LinearLayout>

            <!-- Dish Type and Meal Type Row -->
            <LinearLayout
                android:id="@+id/dish_and_meal_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"
                android:gravity="center_vertical">

                <!-- Dish Type -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/recipe_dish_type"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:text="@string/dish_filter"
                    android:layout_marginEnd="4dp" />

                <!-- Divider Dot -->
                <TextView
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/rounded_dot"
                    android:layout_marginEnd="4dp"
                    android:gravity="center" />

                <!-- Preparation Time -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/recipe_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:text="@string/time_filter" />
            </LinearLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
